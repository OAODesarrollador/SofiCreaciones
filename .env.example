# Copy this file to .env.local and fill values locally.
# SECURITY: NO commitear secretos (tokens, passwords o keys reales).

# TURSO DATABASE
TURSO_DATABASE_URL=libsql://YOUR-DB.turso.io
TURSO_AUTH_TOKEN=YOUR_TURSO_AUTH_TOKEN

# ADMIN ACCESS
ADMIN_PASSWORD=YOUR_ADMIN_PASSWORD
# Optional but recommended (if omitted, it is derived from ADMIN_PASSWORD)
ADMIN_TOKEN_SECRET=YOUR_ADMIN_TOKEN_SECRET

# MERCADO PAGO
MP_ACCESS_TOKEN=YOUR_MP_ACCESS_TOKEN
MP_WEBHOOK_SECRET=YOUR_MP_WEBHOOK_SECRET
FRONTEND_URL=https://your-frontend.example.com
BACKEND_URL=https://your-backend.example.com
NEXT_PUBLIC_MP_PUBLIC_KEY=YOUR_MP_PUBLIC_KEY

# Optional: Google Sheets config (if used)
NEXT_PUBLIC_SHEET_ID=
NEXT_PUBLIC_GID_PRODUCTS=0
NEXT_PUBLIC_GID_COMBOS=123456
NEXT_PUBLIC_GID_CONFIG=789012
